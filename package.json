{
	"name": "voz-y-cuento",
	"version": "1.0.0",
	"description": "A blank template to get started with Payload 3.0",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "NODE_OPTIONS=--no-deprecation next build",
		"dev": "NODE_OPTIONS=--no-deprecation next dev",
		"devsafe": "rm -rf .next && NODE_OPTIONS=--no-deprecation next dev",
		"generate:types": "payload generate:types",
		"format": "prettier ./ --check",
		"format:fix": "prettier ./ --write",
		"lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"lint:fix": "eslint . --fix --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"payload": "NODE_OPTIONS=--no-deprecation payload",
		"start": "NODE_OPTIONS=--no-deprecation next start"
	},
	"dependencies": {
		"@hookform/resolvers": "^3.9.0",
		"@payload-enchants/cached-local-api": "^1.2.2",
		"@payloadcms/db-postgres": "beta",
		"@payloadcms/next": "beta",
		"@payloadcms/plugin-cloud": "beta",
		"@payloadcms/richtext-lexical": "beta",
		"@payloadcms/storage-uploadthing": "beta",
		"autoprefixer": "^10.4.17",
		"babel-plugin-react-compiler": "^0.0.0-experimental-592953e-20240517",
		"clsx": "^2.0.0",
		"graphql": "^16.8.1",
		"jose": "^5.3.0",
		"next": "canary",
		"oslo": "^1.2.1",
		"payload": "beta",
		"react": "rc",
		"react-dom": "rc",
		"react-hook-form": "^7.51.5",
		"react-loader-spinner": "^6.1.6",
		"server-only": "^0.0.1",
		"sharp": "0.32.6",
		"tailwind-merge": "^2.2.0",
		"tailwind-variants": "^0.1.20",
		"tailwindcss": "^3.4.7",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@swc/core": "^1.7.3",
		"@types/node": "^20.12.12",
		"@types/react": "npm:types-react@19.0.0-rc.0",
		"@types/react-dom": "npm:types-react-dom@19.0.0-rc.0",
		"eslint": "^8",
		"eslint-config-next": "canary",
		"eslint-config-prettier": "^9.1.0",
		"typescript": "5.4.2"
	},
	"engines": {
		"node": "^18.20.2 || >=20.9.0"
	},
	"pnpm": {
		"overrides": {
			"@types/react": "npm:types-react@19.0.0-rc.0",
			"@types/react-dom": "npm:types-react-dom@19.0.0-rc.0"
		}
	},
	"overrides": {
		"@types/react": "npm:types-react@19.0.0-rc.0",
		"@types/react-dom": "npm:types-react-dom@19.0.0-rc.0"
	}
}
